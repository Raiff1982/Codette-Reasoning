\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Runtime benchmark latency by category (May 26, 2026). Green bars indicate passing cases (score $\geq $ target); grey bars indicate warnings. Valuation-reasoning queries (pre-computed graph traversal) complete in $\sim $3.4~s; continuity-retention requires multi-turn context loading ($\sim $412~s). Mean latency: 115.2~s; pass rate: 60\%.}}{20}{figure.caption.8}\protected@file@percent }
\newlabel{fig:latency}{{4}{20}{Runtime benchmark latency by category (May 26, 2026). Green bars indicate passing cases (score $\geq $ target); grey bars indicate warnings. Valuation-reasoning queries (pre-computed graph traversal) complete in $\sim $3.4~s; continuity-retention requires multi-turn context loading ($\sim $412~s). Mean latency: 115.2~s; pass rate: 60\%}{figure.caption.8}{}}
\newlabel{fig:latency@cref}{{[figure][4][]4}{[1][11][]20}{}{}{}}
